<?xml version="1.0"?>
<sdf version="1.9">
  <model name="my_robot" canonical_link="base_link">
    <pose>0 0 0 0 0 0</pose>

    <link name="base_footprint">
      <pose>0 0 0 0 0 0</pose>
    </link>

    <link name="base_link">
      <pose>0 0 0.12 0 0 0</pose>

      <inertial>
        <mass>8.0</mass>
        <inertia>
          <ixx>0.12</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.25</iyy>
          <iyz>0.0</iyz>
          <izz>0.30</izz>
        </inertia>
      </inertial>

      <collision name="collision">
        <geometry>
          <box>
            <size>0.60 0.40 0.15</size>
          </box>
        </geometry>
      </collision>

      <visual name="visual">
        <geometry>
          <box>
            <size>0.60 0.40 0.15</size>
          </box>
        </geometry>
        <material>
          <ambient>0.1 0.3 0.8 1.0</ambient>
          <diffuse>0.1 0.3 0.8 1.0</diffuse>
        </material>
      </visual>
    </link>

    <link name="laser_link">
      <pose>0.20 0 0.22 0 0 0</pose>

      <inertial>
        <mass>0.2</mass>
        <inertia>
          <ixx>0.0005</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.0005</iyy>
          <iyz>0.0</iyz>
          <izz>0.0005</izz>
        </inertia>
      </inertial>

      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.07</radius>
            <length>0.05</length>
          </cylinder>
        </geometry>
      </collision>

      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.07</radius>
            <length>0.05</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.9 0.1 0.1 1.0</ambient>
          <diffuse>0.9 0.1 0.1 1.0</diffuse>
        </material>
      </visual>

      <sensor name="laser_sensor" type="gpu_lidar">
        <pose>0 0 0 0 0 0</pose>
        <topic>/scan</topic>
        <update_rate>10</update_rate>
        <gz_frame_id>laser_link</gz_frame_id>

        <lidar>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.12</min>
            <max>10.0</max>
            <resolution>0.01</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.01</stddev>
          </noise>
        </lidar>
        <always_on>true</always_on>
        <visualize>true</visualize>
      </sensor>
    </link>

    <link name="left_wheel_link">
      <pose>0 0.23 0.08 -1.57079632679 0 0</pose>
      <inertial>
        <mass>0.8</mass>
        <inertia>
          <ixx>0.002</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.002</iyy>
          <iyz>0.0</iyz>
          <izz>0.002</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
            </ode>
          </friction>
        </surface>
        <geometry>
          <cylinder>
            <radius>0.08</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.08</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1.0</ambient>
          <diffuse>0.02 0.02 0.02 1.0</diffuse>
        </material>
      </visual>
    </link>

    <link name="right_wheel_link">
      <pose>0 -0.23 0.08 -1.57079632679 0 0</pose>
      <inertial>
        <mass>0.8</mass>
        <inertia>
          <ixx>0.002</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.002</iyy>
          <iyz>0.0</iyz>
          <izz>0.002</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
            </ode>
          </friction>
        </surface>
        <geometry>
          <cylinder>
            <radius>0.08</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.08</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1.0</ambient>
          <diffuse>0.02 0.02 0.02 1.0</diffuse>
        </material>
      </visual>
    </link>

    <link name="caster_swivel_link">
      <pose>-0.24 0 0.04 0 0 0</pose>
      <inertial>
        <mass>0.05</mass>
        <inertia>
          <ixx>0.00002</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.00002</iyy>
          <iyz>0.0</iyz>
          <izz>0.00002</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry>
          <sphere>
            <radius>0.015</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.45 0.45 0.45 1.0</ambient>
          <diffuse>0.45 0.45 0.45 1.0</diffuse>
        </material>
      </visual>
    </link>

    <link name="caster_wheel_link">
      <pose>-0.24 0 0.04 1.57079632679 0 0</pose>
      <inertial>
        <mass>0.15</mass>
        <inertia>
          <ixx>0.0001</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.0001</iyy>
          <iyz>0.0</iyz>
          <izz>0.0001</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <surface>
          <friction>
            <ode>
              <mu>0.15</mu>
              <mu2>0.08</mu2>
            </ode>
          </friction>
        </surface>
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.025</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.025</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.45 0.45 0.45 1.0</ambient>
          <diffuse>0.45 0.45 0.45 1.0</diffuse>
        </material>
      </visual>
    </link>

    <joint name="base_joint" type="fixed">
      <parent>base_footprint</parent>
      <child>base_link</child>
      <pose relative_to="base_footprint">0 0 0.12 0 0 0</pose>
    </joint>

    <joint name="laser_joint" type="fixed">
      <parent>base_link</parent>
      <child>laser_link</child>
      <pose relative_to="base_link">0.20 0 0.10 0 0 0</pose>
    </joint>

    <joint name="caster_swivel_joint" type="revolute">
      <parent>base_link</parent>
      <child>caster_swivel_link</child>
      <pose relative_to="base_link">-0.24 0 -0.08 0 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
        <dynamics>
          <damping>0.08</damping>
          <friction>0.0</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="caster_wheel_joint" type="revolute">
      <parent>caster_swivel_link</parent>
      <child>caster_wheel_link</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
        <dynamics>
          <damping>0.03</damping>
          <friction>0.0</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>left_wheel_link</child>
      <pose relative_to="base_link">0 0.23 -0.04 -1.57079632679 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
          <effort>20</effort>
          <velocity>20</velocity>
        </limit>
      </axis>
    </joint>

    <joint name="right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>right_wheel_link</child>
      <pose relative_to="base_link">0 -0.23 -0.04 -1.57079632679 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
          <effort>20</effort>
          <velocity>20</velocity>
        </limit>
      </axis>
    </joint>

    <plugin
      filename="gz-sim-diff-drive-system"
      name="gz::sim::systems::DiffDrive">

      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>

      <wheel_separation>0.46</wheel_separation>
      <wheel_radius>0.08</wheel_radius>

      <odom_publish_frequency>50</odom_publish_frequency>
      <max_velocity>1.0</max_velocity>
      <max_linear_acceleration>0.2</max_linear_acceleration>

      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
    </plugin>
  </model>
</sdf>
